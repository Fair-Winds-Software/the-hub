{
  "name": "@maverick-launch/hub-service",
  "version": "0.0.1",
  "private": true,
  "description": "Maverick Launch HUB — Central control plane for billing, licensing, entitlements, and usage",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/rate-limit": "^11.0.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "pino": "^9.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@vitest/coverage-v8": "^1.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^1.6.0"
  }
}
