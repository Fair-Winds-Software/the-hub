{
  "name": "@maverick-launch/hub-service",
  "version": "0.0.1",
  "private": true,
  "description": "Maverick Launch HUB — Central control plane for billing, licensing, entitlements, and usage",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ packages/",
    "frontend:install": "cd frontend && npm install",
    "frontend:dev": "cd frontend && npm run dev",
    "frontend:build": "cd frontend && npm run build",
    "frontend:preview": "cd frontend && npm run preview",
    "frontend:test": "cd frontend && npm run test",
    "frontend:typecheck": "cd frontend && npm run typecheck",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:e2e": "cd frontend && npm run e2e",
    "frontend:e2e:install": "cd frontend && npm run e2e:install",
    "frontend:lighthouse": "cd frontend && npm run lighthouse"
  },
  "dependencies": {
    "@fastify/compress": "^8.0.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "@fastify/static": "^8.1.1",
    "@types/nodemailer": "^8.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "fflate": "^0.8.3",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^9.0.0",
    "pg": "^8.11.3",
    "pino": "^9.2.0",
    "stripe": "^22.2.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@vitest/coverage-v8": "^1.6.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^1.6.0"
  }
}
