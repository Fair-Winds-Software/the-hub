# HUB Service — Environment Variables
# Copy to .env and fill in values

# Docker host ports (per-project allocation D-FW-INFRA-002)
# HUB keeps canonical 5432/6379/8080 as the Fair Winds billing/licensing spine.
# Internal container ports stay 5432/6379/8080 — only host-side mapping varies per project.
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8080

# PostgreSQL connection string
DATABASE_URL=postgresql://hub:hub@localhost:5432/hub_dev

# Connection pool settings
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT_MS=30000

# Redis connection string (HUB-77)
REDIS_URL=redis://localhost:6379

# ── JWT secrets (HUB-77, HUB-112) ────────────────────────────────────────────
# 256-bit random strings. Generate via: openssl rand -hex 32
JWT_SECRET=
OPERATOR_JWT_SECRET=

# ── Encryption keys (HUB-1525, HUB-4.1 L2) ───────────────────────────────────
# Exactly 64 hex characters = 32-byte AES-256 key. Generate via: openssl rand -hex 32
LEASE_ENCRYPTION_KEY=
HOOK_ENCRYPTION_KEY=

# ── Stripe (HUB-1525, HUB-4.1 L2) ────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SIGNING_SECRET=

# ── Atlassian Jira (HUB-1592 CR-1) ───────────────────────────────────────────
# Atlassian Cloud REST v3 = Basic auth with base64("email:token") per D-HUB-SCOPE-029.
# Token provisioned from Atlassian admin → service account → API token. See
# docs/integrations/atlassian-jira.md for the provisioning + 90-day rotation procedure.
JIRA_SERVICE_TOKEN=
JIRA_SERVICE_EMAIL=

# ── Optional ─────────────────────────────────────────────────────────────────
# BCRYPT_ROUNDS=12     # default 12; lower in tests for speed
# NODE_ENV=development # development | test | production
